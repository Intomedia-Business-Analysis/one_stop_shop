DB_SERVER=
DB_NAME=
DB_USER=
DB_PASSWORD=

# Session-nøgle (PÅKRÆVET) — appen starter ikke uden. Generér én med:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Semikolon-separeret liste af stier til Zuora snapshot mapper
ZUORA_SNAPSHOT_DIR=

# Pipedrive API-tokens — bruges af Portfolio Alignment til at oprette
# afstemnings-deals ("Porteføljeafstemning 2026") direkte fra UI'en.
PD_TOKEN_WATCH_DK_FINANS=
PD_TOKEN_WATCH_NO=
PD_TOKEN_WATCH_SE=
PD_TOKEN_WATCH_DE=
PD_TOKEN_MONITOR=
# JP/POL Advertising — bruges af Klippekort Overblik til at opdatere
# feltet "klip brugt" (used_clip_cards) på job-deals via Pipedrive API.
PD_TOKEN_JPPOL=

# ── Barselsplanlægger: mail-notifikation ved godkendelse ────────────
# Microsoft 365 SMTP er default. Hvis SMTP_USER eller SMTP_PASSWORD
# er tomme, springes afsendelsen over uden fejl (godkendelsen står ved magt).
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=
SMTP_USE_TLS=1
# Hvis du får CERTIFICATE_VERIFY_FAILED (virksomhedsproxy/TLS-inspektion):
#   - peg på en CA-bundle, fx Zscaler-rootcert: SMTP_CA_BUNDLE=C:/certs/zscaler-root.pem
#   - eller spring verificering over som lynfix:   SMTP_SSL_VERIFY=0
SMTP_CA_BUNDLE=
SMTP_SSL_VERIFY=1